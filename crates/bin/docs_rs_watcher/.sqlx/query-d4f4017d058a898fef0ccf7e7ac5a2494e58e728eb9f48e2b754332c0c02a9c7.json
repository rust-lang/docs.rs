  "query": "SELECT\n                    id,\n                    name as \"name: KrateName\",\n                    version as \"version: Version\",\n                    priority,\n                    attempt\n                 FROM queue\n                 WHERE\n                    last_attempt IS NULL OR last_attempt < NOW() - make_interval(secs => $1)\n                 ORDER BY priority ASC, attempt ASC, id ASC\n                 LIMIT 1\n                 FOR UPDATE SKIP LOCKED",
